# Mobile production env — committed so external users can build a personal
# Android/iPhone copy that defaults to agent.diff.host, while the app-level
# backend picker can still switch to other bundled deployments later.
# Loaded by the `*:prod` scripts via dotenv-cli (see package.json).
EXPO_PUBLIC_API_URL=https://agent.diff.host
EXPO_PUBLIC_WEB_URL=https://agent.diff.host
